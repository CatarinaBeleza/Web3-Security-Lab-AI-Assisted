// SPDX-License-Identifier: MITpragma solidity ^0.8.0;contract VaultV4 {    address public owner;    mapping(address => uint256) public balances;    bool public initialized;    // Vulnerabilidade: InicializańŃo insegura    function init() public {        require(!initialized, "Already initialized");        owner = msg.sender;        initialized = true;    }    function deposit() public payable {        balances[msg.sender] += msg.value;    }    function withdrawAll() public {        require(msg.sender == owner, "Not the owner");        payable(msg.sender).transfer(address(this).balance);    }        // Fallback para receber Ether    receive() external payable {}}
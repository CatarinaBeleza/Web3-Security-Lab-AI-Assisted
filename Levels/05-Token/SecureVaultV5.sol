// SPDX-License-Identifier: MITpragma solidity ^0.8.0;contract SecureVaultV5 {address public owner;    constructor() payable {        owner = msg.sender;    }    // VULNERABILIDADE: O uso de tx.origin permite ataques de phishing    function transfer(address payable _to, uint256 _amount) public {        require(tx.origin == owner, "Apenas o dono pode transferir");                (bool sent, ) = _to.call{value: _amount}("");        require(sent, "Falha ao enviar Ether");    }    receive() external payable {}}